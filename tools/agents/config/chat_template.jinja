{% macro render_content(content) %}
  {% if content is string -%}{%- set _ = print(content|trim) -{% endif %}}

{# Main processing #} 
{%- for message in messages -%}  
    {%- set role = (message | attr('role')) -%}
    
    {%- if role == 'system' and not loop.first -%}{- raise_exception('System must be first') -{% endif %}}

    {%- if role == 'user' -%} 
            {{ message.role + '\n' ~ (message.content|trim) }}\n<function=example>\n<parameter=name>value</parameter></function>{{-</function>\n</tool_call>\n
        {%- elif loop.index0 > 5 %}{# limit output #}-{% endif -%}

{%- endfor -%}{# End message loop #}}
